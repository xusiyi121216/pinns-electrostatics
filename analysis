    errors_noise.append(rel_err)
    epsilons_noise.append(eps_pred)
    print(f"epsilon={eps_pred:.4f}, error={rel_err:.4f}%")

noise_labels = [f'{int(n * 100)}%' for n in noise_list]

fig, axes = plt.subplots(1, 2, figsize=(12, 4))

axes[0].bar(noise_labels, errors_noise, color='steelblue', edgecolor='black')
axes[0].set_xlabel('Noise Level')
axes[0].set_ylabel('Relative Error (%)')
axes[0].set_title('Effect of Measurement Noise on\nPermittivity Identification')
axes[0].grid(True, axis='y')
for i, e in enumerate(errors_noise):
    axes[0].text(i, e + 0.01, f'{e:.3f}%', ha='center', fontsize=9)

axes[1].plot(noise_labels, epsilons_noise, 'rs-', linewidth=2, markersize=8, label='Predicted ε')
axes[1].axhline(y=EPSILON_TRUE, color='b', linestyle='--', linewidth=2, label=f'True ε={EPSILON_TRUE}')
axes[1].set_xlabel('Noise Level')
axes[1].set_ylabel('Predicted ε')
axes[1].set_title('Predicted Permittivity vs\nMeasurement Noise Level')
axes[1].legend()
axes[1].grid(True)

plt.suptitle('Noise Robustness Analysis', fontsize=13)
plt.tight_layout()
plt.savefig('figures/noise_robustness.png', dpi=150)
plt.show()
print("Figure saved: figures/noise_robustness.png\n")

