import torch
import torch.optim as optim
import numpy as np
import matplotlib.pyplot as plt
from model import PINN
from utils import generate_collocation_points, generate_boundary_points, plot_results

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device}")

torch.manual_seed(42)
np.random.seed(42)

model = PINN(layers=[2, 50, 50, 50, 50, 1]).to(device)
optimizer = optim.Adam(model.parameters(), lr=1e-3)
scheduler = optim.lr_scheduler.StepLR(optimizer, step_size=2000, gamma=0.5)

x_col, y_col = generate_collocation_points(n_points=3000, device=device)
x_bc, y_bc, phi_bc = generate_boundary_points(n_points=200, device=device)

def pde_residual(model, x, y):
    x = x.requires_grad_(True)
    y = y.requires_grad_(True)

    phi = model(x, y)

    phi_x = torch.autograd.grad(
        phi, x,
        grad_outputs=torch.ones_like(phi),
        create_graph=True
    )[0]

    phi_y = torch.autograd.grad(
        phi, y,
        grad_outputs=torch.ones_like(phi),
        create_graph=True
    )[0]

    phi_xx = torch.autograd.grad(
        phi_x, x,
        grad_outputs=torch.ones_like(phi_x),
        create_graph=True
    )[0]

    phi_yy = torch.autograd.grad(
        phi_y, y,
        grad_outputs=torch.ones_like(phi_y),
        create_graph=True
    )[0]

    residual = phi_xx + phi_yy
    return residual

def compute_loss(model, x_col, y_col, x_bc, y_bc, phi_bc):
    residual = pde_residual(model, x_col, y_col)
    loss_pde = torch.mean(residual ** 2)

    phi_pred_bc = model(x_bc, y_bc)
    loss_bc = torch.mean((phi_pred_bc - phi_bc) ** 2)

    loss = loss_pde + 10.0 * loss_bc
    return loss, loss_pde, loss_bc

n_epochs = 10000
loss_history = []

print("Starting Adam training...")

for epoch in range(n_epochs):
    model.train()
    optimizer.zero_grad()

    loss, loss_pde, loss_bc = compute_loss(model, x_col, y_col, x_bc, y_bc, phi_bc)

    loss.backward()
    optimizer.step()
    scheduler.step()

    loss_history.append(loss.item())

    if epoch % 500 == 0:
        print(
            f"Epoch {epoch:5d} | Loss: {loss.item():.6f} | "
            f"PDE: {loss_pde.item():.6f} | BC: {loss_bc.item():.6f}"
        )

torch.save(model.state_dict(), 'forward_model.pth')
print("Model saved to forward_model.pth")

plt.figure(figsize=(8, 4))
plt.semilogy(loss_history)
plt.xlabel('Epoch')
plt.ylabel('Loss')
plt.title('Training Loss (Adam)')
plt.grid(True)
plt.savefig('figures/loss_curve_adam.png', dpi=150)
plt.show()

print("\nAdam training results:")
plot_results(model, device=device, title='Forward Problem Adam')

print("\nStarting L-BFGS refinement...")

optimizer_lbfgs = optim.LBFGS(
    model.parameters(),
    lr=1.0,
    max_iter=500,
    max_eval=500,
    tolerance_grad=1e-7,
    tolerance_change=1e-9,
    history_size=50,
    line_search_fn='strong_wolfe'
)

lbfgs_loss_history = []

def closure():
    optimizer_lbfgs.zero_grad()
    loss, loss_pde, loss_bc = compute_loss(model, x_col, y_col, x_bc, y_bc, phi_bc)
    loss.backward()
    lbfgs_loss_history.append(loss.item())
    return loss

optimizer_lbfgs.step(closure)

print(f"L-BFGS completed | Final Loss: {lbfgs_loss_history[-1]:.6f}")

torch.save(model.state_dict(), 'forward_model_final.pth')

print("\nResults after L-BFGS optimization:")
plot_results(model, device=device, title='Forward Problem LBFGS')

print("\nTraining finished")